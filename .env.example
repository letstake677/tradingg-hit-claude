# Copy this file to ".env" and fill in YOUR OWN values there.
# NEVER commit .env to git. NEVER paste your real key/secret/passphrase into a chat.

# --- Bitget credentials: OPTIONAL here now ---
# You can either fill these in as a bootstrap/fallback, OR attach keys
# through the dashboard's Connect tab (they get encrypted and stored in the
# database instead). The database is checked first; these are the fallback.
# Demo and live need SEPARATE keys — Bitget will not accept a demo key in
# live mode or vice versa.
BITGET_DEMO_API_KEY=
BITGET_DEMO_API_SECRET=
BITGET_DEMO_PASSPHRASE=
BITGET_LIVE_API_KEY=
BITGET_LIVE_API_SECRET=
BITGET_LIVE_PASSPHRASE=

# USDT-FUTURES, COIN-FUTURES, or USDC-FUTURES
BITGET_PRODUCT_TYPE=USDT-FUTURES

# Timezone the daily-loss circuit breaker's "today" resets in — a proper
# IANA name, not an offset (e.g. "Asia/Karachi", not "+5"). Defaults to UTC
# if unset, which means "today" resets at UTC midnight regardless of where
# you actually are.
TIMEZONE=UTC

# --- Security ---

# Required if you want to attach/change API keys or switch to live mode
# through the dashboard. Keep this private — it's checked server-side only,
# never sent to or stored in the browser. A wrong guess 5 times in a row
# locks it out for 15 minutes, which is what actually stops brute-forcing a
# short PIN — but still pick something you wouldn't mind being a real
# password, not literally "0011".
LIVE_MODE_PIN=0011

# Required for the dashboard's Connect tab to work at all — this is the key
# that encrypts Bitget credentials before they're stored in the database.
# Generate ONE and keep it exactly as generated:
#   python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
CREDENTIAL_ENCRYPTION_KEY=

# --- Risk settings (defaults — also editable from the dashboard's Settings tab) ---
RISK_PER_TRADE_PCT=1.0
MAX_CONCURRENT_POSITIONS=3
MAX_DAILY_LOSS_PCT=5.0
